# GitHub OAuth App (create at https://github.com/settings/developers)
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
# Must exactly match the callback URL configured on the OAuth App
GITHUB_OAUTH_REDIRECT_URL=https://your-backend.onrender.com/auth/callback
# Shared secret used to sign/verify webhook payloads (any long random string).
# You pass this same value when the app creates each repo webhook.
GITHUB_WEBHOOK_SECRET=any_long_random_string

# Slack app OAuth settings
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
# Must match the Redirect URL configured in your Slack app
SLACK_OAUTH_REDIRECT_URL=https://your-backend.onrender.com/auth/slack/callback

# Optional fallback if you still want webhook-based posting
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/SLACK/WEBHOOK

# Neon/Supabase Postgres connection string. Leave unset to fall back to local sqlite.
DATABASE_URL=postgresql://user:password@host/dbname

# Any long random string, used to sign session cookies
SESSION_SECRET=any_long_random_string_here

# Your deployed frontend URL (Vercel), used for CORS + post-login redirect
FRONTEND_URL=https://your-frontend.vercel.app

# Optional - only needed for the AI triage stretch goal
GEMINI_API_KEY=your_gemini_api_key

ENV=development
